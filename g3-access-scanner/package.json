{
  "name": "g3-access-scanner",
  "version": "0.1.0",
  "description": "Scanner powering the G3 Access remediation plugin. Fork of the audit-pipeline scanner with single-page + URL-discovery subcommands.",
  "private": true,
  "type": "module",
  "bin": {
    "scanner": "./dist/cli.js"
  },
  "scripts": {
